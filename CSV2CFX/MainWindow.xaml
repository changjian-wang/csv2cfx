<Window x:Class="CSV2CFX.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CSV2CFX"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Height="415" Width="780">
            <TextBlock Text="CSV2CFX Service"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center" />

            <Button x:Name="CheckUpdateButton" 
                    Content="立即检查更新" 
                    Width="150" 
                    Height="30"
                    Margin="0,0,0,10"
                    Click="CheckUpdateButton_Click"/>
            
            <TextBlock Text="自动更新功能已启用，应用启动时和每天会自动检查更新。"
                       TextWrapping="Wrap"
                       Width="330"
                       TextAlignment="Center"
                       Foreground="Gray"/>

            <Button 
                x:Name="StartServiceButton" 
                Content="启动服务" 
                Width="150" 
                Height="30" 
                Margin="0,20,0,0"
                Click="StartServiceButton_Click" />

            <TextBlock x:Name="ServiceStatusText"
                       Text="服务状态：已停止"
                       Foreground="Red"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,10"/>

            <TextBlock x:Name="ServiceLogText"
                       Text=""
                       TextWrapping="Wrap"
                       Width="500"
                       MaxHeight="200"
                       HorizontalAlignment="Center"
                       Foreground="DarkBlue"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"/>
        </StackPanel>
    </Grid>
</Window>
